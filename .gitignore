# Rust
/target
**/*.rs.bk
*.pdb

# Built frontend (regenerated by `make frontend`; embedded at build time)
/frontend/dist
/frontend/node_modules
/frontend/coverage

# Local databases
*.db
*.db-shm
*.db-wal

# Downloaded game data (master/elite PGN dumps, archives) — not committed
/data

# Downloaded engines / weights
/engines

# Per-target Stockfish embedded by the `bundled-stockfish` feature
# (`make bundle-stockfish`); a GPLv3 binary that must not be committed.
/engines-bundled

# Env / editor
.env
.DS_Store
