# chess-base server deployment — copy to `.env` and edit before `docker compose up`.

# Postgres credentials (also used to build the app's DATABASE_URL).
POSTGRES_USER=chess
POSTGRES_PASSWORD=change-me
POSTGRES_DB=chessbase

# Host port the app is published on (container always listens on 3030).
APP_PORT=3030

# Backend log level (tracing EnvFilter syntax).
RUST_LOG=info
