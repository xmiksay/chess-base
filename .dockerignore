# Build artifacts and local state — rebuilt inside the image, never copied in.
target
**/*.rs.bk
*.pdb

frontend/dist
frontend/node_modules
frontend/coverage

# Local databases / downloaded engines
*.db
*.db-shm
*.db-wal
engines
# The image fetches its own Stockfish (make bundle-stockfish) — never copy a
# host-target binary in.
engines-bundled

# VCS / env / editor / docs not needed in the image
.git
.github
.env
.DS_Store
docs
